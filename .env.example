# Frontend local. En Docker Space dejar vacío para llamar al mismo host.
VITE_API_BASE_URL=

# Carga opcional de Transformers.js desde CDN.
VITE_TRANSFORMERS_JS_CDN=https://cdn.jsdelivr.net/npm/@huggingface/transformers@3

# Backend
# Las variables ATTENTIONLAB_* se conservan por compatibilidad durante la Fase 1.
PORT=7860
ATTENTIONLAB_STATIC_DIR=/app/static
ATTENTIONLAB_ENABLE_MODEL_ADAPTERS=true
ATTENTIONLAB_ENABLE_REAL_MODELS=false
ATTENTIONLAB_DEFAULT_MODEL_ID=
ATTENTIONLAB_TEXT_MODEL_ID=distilbert-base-uncased
ATTENTIONLAB_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
